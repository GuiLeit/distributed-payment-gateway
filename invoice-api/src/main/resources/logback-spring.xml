<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="invoice-api"/>
    <springProperty scope="context" name="instanceId"  source="app.instance-id"         defaultValue="local"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${serviceName}","instance":"${instanceId}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <logger>logger</logger>
                <thread>thread</thread>
                <version>[ignore]</version>
            </fieldNames>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
